# Copia este archivo como .env y ajusta los valores

# Puerto donde escucha la API
PORT=3000

# Cadena de conexión a MongoDB
# Local:  mongodb://127.0.0.1:27017/serviciosweb
# Atlas:  mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/serviciosweb
MONGODB_URI=mongodb://127.0.0.1:27017/serviciosweb

# Secreto para firmar los tokens JWT. CÁMBIALO por una cadena larga y aleatoria.
JWT_SECRET=cambia_este_secreto_en_produccion

# Tiempo de vida del token (formato de la librería jsonwebtoken: 5m, 1h, 7d...)
JWT_EXPIRES=5m
